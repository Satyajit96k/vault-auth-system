# Server
NODE_ENV=development
PORT=5000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/auth_db?schema=public

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# JWT — Generate secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-256-bit-secret-minimum-32-characters-long
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_ISSUER=auth-server
JWT_AUDIENCE=auth-client

# Cookies
COOKIE_SECRET=your-cookie-signing-secret-minimum-32-chars
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# CORS
FRONTEND_URL=http://localhost:3000

# Rate Limiting
RATE_LIMIT_REGISTER_POINTS=3
RATE_LIMIT_REGISTER_DURATION=600
RATE_LIMIT_LOGIN_POINTS=5
RATE_LIMIT_LOGIN_DURATION=60
RATE_LIMIT_LOGIN_BLOCK=300
RATE_LIMIT_REFRESH_POINTS=10
RATE_LIMIT_REFRESH_DURATION=60
RATE_LIMIT_ME_POINTS=30
RATE_LIMIT_ME_DURATION=60
RATE_LIMIT_GLOBAL_POINTS=100
RATE_LIMIT_GLOBAL_DURATION=60

# IP Whitelisting
IP_WHITELIST_ENABLED=false
IP_WHITELIST_MODE=allowlist
IP_WHITELIST_IPS=127.0.0.1,::1

# Logging
LOG_LEVEL=debug

# Bcrypt
BCRYPT_SALT_ROUNDS=12
